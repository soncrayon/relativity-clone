# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
# Format: postgresql://username:password@host:port/database_name
# The app user is created by the setup steps in COMMANDS.md
DATABASE_URL=postgresql://relativity_app:your_password@127.0.0.1:5432/relativity

# Set to "true" to enable verbose error responses (never use in production)
DEBUG=true

# Comma-separated list of allowed frontend origins for CORS
# The React dev server runs on port 9000
# Comma-separated, no spaces: http://localhost:9000,http://localhost:3000
CORS_ORIGINS_STR=http://localhost:9000
